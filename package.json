{
  "name": "claude-memd",
  "version": "1.0.0",
  "description": "Delete companion for claude-mem - provides view and delete functionality on port 27778",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-memd": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:bun:sqlite",
    "build:viewer": "esbuild src/viewer/index.tsx --bundle --platform=browser --format=esm --outfile=dist/viewer.js --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:setup": "bun test tests/setup.test.ts",
    "test:api": "bun test tests/api.test.ts",
    "test:integration": "bun test tests/integration.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "delete",
    "claude-mem"
  ],
  "author": "James Moore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesturingmoore/claude-memd.git"
  }
}
