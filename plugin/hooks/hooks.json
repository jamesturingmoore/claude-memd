{
  "description": "Claude-memd HTTP server hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.js\" \"${CLAUDE_PLUGIN_ROOT}/scripts/http-server.cjs\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
