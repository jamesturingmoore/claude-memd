{
  "description": "Claude-memd HTTP server hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/cache/jamesturingmoore/claude-memd/1.0.1\"; node \"$_R/scripts/bun-runner.js\" \"$_R/scripts/http-server.cjs\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
